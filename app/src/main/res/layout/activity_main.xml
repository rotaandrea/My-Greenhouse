<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glass_gradient"
    tools:context=".MainActivity">

    <!-- Pulsante di Logout in alto a destra -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnLogout"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="#33FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#80FFFFFF"
        app:strokeWidth="1.5dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/ic_logout"
            app:tint="#FFFFFF" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Card contenitore in Vetro Liquido (Glassmorphism) -->
    <!-- app:cardElevation="0dp" è CRUCIALE per non rovinare la trasparenza con ombre nere solide -->

    <!-- Layout di Status -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#33FFFFFF"
        app:cardCornerRadius="125dp"
        app:cardElevation="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.48"
        app:layout_constraintBottom_toTopOf="@+id/statusLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.69"
        app:layout_constraintVertical_chainStyle="packed"
        app:strokeColor="#80FFFFFF"
        app:strokeWidth="1.5dp">

        <ImageView
            android:id="@+id/imageViewMascotte"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:contentDescription="Mascotte della serra"
            android:longClickable="false"
            android:padding="@dimen/cardview_default_radius"
            android:scaleType="centerCrop"
            android:src="@mipmap/normale" />

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/statusLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/humidityCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageContainer">

        <ImageView
            android:id="@+id/imageStatus"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_check_circle"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sf_armenian_rounded"
            android:letterSpacing="0.02"
            android:text="TUTTO BENE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Card principale Umidità in Vetro Smerigliato -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/humidityCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="#4DFFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/controlsLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/statusLayout"
        app:strokeColor="#B3FFFFFF"
        app:strokeWidth="1.5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/textPercentualeUmid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/sf_armenian_rounded"
                android:includeFontPadding="false"
                android:shadowColor="#26000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="10"
                android:text="80%"
                android:textColor="#FFFFFF"
                android:textSize="58sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textLabelUmid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/sf_armenian_rounded"
                android:letterSpacing="0.05"
                android:text="Umidità Attuale"
                android:textColor="#E0F2F1"
                android:textSize="16sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Layout Pulsanti Circolari (Irrigazione e Auto) Allineati Orizzontalmente -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="40dp"
        android:padding="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/nav_bar_pill"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/humidityCard">

        <!-- Pulsante Irrigazione Circolare -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnIrrigazioneContainer"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="24dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardCornerRadius="32dp"
            app:cardElevation="6dp"
            android:outlineAmbientShadowColor="#4D000000"
            android:outlineSpotShadowColor="#4D000000"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1.5dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/imgIrrigazione"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_water_drop"
                app:tint="#FFFFFF"
                android:clickable="false"
                android:focusable="false"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pulsante Auto Circolare -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnAutoContainer"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="24dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardCornerRadius="32dp"
            app:cardElevation="6dp"
            android:outlineAmbientShadowColor="#4D000000"
            android:outlineSpotShadowColor="#4D000000"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1.5dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/imgAuto"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_automatic_mode"
                app:tint="#FFFFFF"
                android:clickable="false"
                android:focusable="false"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pulsante Luci Circolare -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnLuciContainer"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardCornerRadius="32dp"
            app:cardElevation="6dp"
            android:outlineAmbientShadowColor="#4D000000"
            android:outlineSpotShadowColor="#4D000000"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1.5dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/imgLuci"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lightbulb"
                app:tint="#FFFFFF"
                android:clickable="false"
                android:focusable="false"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Barra di Navigazione Fluttuante (Stile Instagram Pill) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/nav_bar_pill"
        android:layout_width="180dp"
        android:layout_height="50dp"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="25dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Effetto Vetro (Nativo, senza errori) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/glass_background" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Pulsante Serra -->
            <FrameLayout
                android:id="@+id/btnSerra"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_greenhouse"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <!-- Pulsante Storico -->
            <FrameLayout
                android:id="@+id/btnStorico"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_history"
                    app:tint="#8E8E93" />
            </FrameLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Schermata di Caricamento (Overlay) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glass_gradient"
        android:clickable="true"
        android:focusable="true"
        android:elevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:id="@+id/progressBarLoading"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/sf_armenian_rounded"
            android:text="@string/connessione_db"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/progressBarLoading" />
    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>