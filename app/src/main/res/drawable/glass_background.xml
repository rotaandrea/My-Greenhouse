<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Colore nero/scuro semi-trasparente per l'effetto Glass Mimetico di Instagram -->
    <solid android:color="#991C1C1E"/>
    
    <!-- Bordi completamente arrotondati (a "pillola") -->
    <corners android:radius="40dp"/>

    <!-- Un bordino sottilissimo per dare l'effetto di riflesso del vetro -->
    <stroke 
        android:width="0.5dp" 
        android:color="#4DFFFFFF"/>
</shape>
